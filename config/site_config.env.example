# Kopiere diese Datei nach config/site_config.env und passe alle Werte an.
# Erst nach vollständiger Prüfung SITE_CONFIG_CONFIRMED=YES setzen.

SITE_CONFIG_CONFIRMED=NO

# Pflicht: SolarEdge
CHARGE_LIMIT_ENTITY=number.solaredge_i1_storage_charge_limit
DISCHARGE_LIMIT_ENTITY=
BATTERY_SOE_ENTITY=sensor.solaredge_i1_b1_state_of_energy
BATTERY_CAPACITY_ENTITY=sensor.solaredge_i1_b1_maximum_energy
BACKUP_RESERVE_ENTITY=number.solaredge_i1_backup_reserve

# Pflicht: PV-Prognosen / Wetter
PV_TODAY_REMAINING_ENTITY=
PV_TODAY_TOTAL_ENTITY=
PV_TOMORROW_ENTITY=
PV_OVERMORROW_ENTITIES=
FORECAST_NOW_ENTITY=
WEATHER_ENTITY=

# Pflicht: lokale Leistungssensoren in W
LIVE_PV_POWER_ENTITIES=
LIVE_CONSUMPTION_POWER_ENTITIES=

# Optional: heutiger PV-Ertrag seit Mitternacht, Energie in Wh/kWh/MWh.
# Mehrere Entity-IDs können kommasepariert als Fallback-Liste angegeben werden.
# Bei gültigem PV-Gesamtzähler kann der Eintrag leer bleiben; dann wird der
# interne sensor.se_nf_pv_actual_today_meter automatisch verwendet.
ACTUAL_PV_TODAY_ENTITIES=

# Optional: heutiger kumulierter Hausverbrauch in kWh – kein Durchschnitt.
# Das 7-Tage-Verbrauchsprofil berechnet das Package aus der Historie selbst.
DAILY_CONSUMPTION_ENTITY=

# Optional: fortlaufender PV-Gesamtenergiezähler in Wh/kWh/MWh.
# Normalerweise state_class total oder total_increasing.
PV_ACTUAL_METER_SOURCE_ENTITY=

# Optionaler Rückkanal von evcc zu Home Assistant.
# Bei externem evcc, das nur HA liest, leer lassen.
EVCC_BATTERY_MODE_ENTITY=
SQL_DB_PATH=/config/home-assistant_v2.db

# Einmalige, konservative Startwerte – vor Anwendung fachlich prüfen
MAX_SENSOR_AGE_S=1800
CLOSED_CHARGE_LIMIT_W=0
OPEN_CHARGE_LIMIT_W=5000
TARGET_SOC_PCT=100
PLANNING_CHARGE_POWER_W=3000
START_SAFETY_BUFFER_MIN=30
MIN_START_HOUR=8
LATEST_FINISH_HOUR=18
SESSION_END_GRACE_MIN=30
LOW_SOC_FLOOR_PCT=25
MANUAL_DAILY_CONSUMPTION_KWH=8
LOAD_FORECAST_SAFETY_FACTOR=1.05
COVERAGE_LEAD_MAX_MIN=120
WEATHER_CURRENT_WEIGHT_PCT=20
WEATHER_MISSING_FORECAST_FACTOR=0.85
WEATHER_MAX_LEAD_MIN=90
REPLAN_THRESHOLD_MIN=30
WRITE_MIN_DELTA_W=100
WRITE_COOLDOWN_S=300
WRITE_LOCK_S=60

# Akku-schonen – vor Anwendung prüfen
LIFETIME_MIN_START_HOUR=10
LIFETIME_LATEST_FINISH_HOUR=18
LIFETIME_START_SAFETY_BUFFER_MIN=30
LIFETIME_MIN_SOC_PCT=30
LIFETIME_MAX_SOC_PCT=85
LIFETIME_MIN_TARGET_SOC_PCT=50
LIFETIME_MAX_TARGET_SOC_PCT=80
LIFETIME_SAFETY_KWH=1
LIFETIME_NIGHT_FALLBACK_KWH=4.5
LIFETIME_SOC_BUFFER_PCT=20
EARLY_OPEN_DEFICIT_KWH=0.5
